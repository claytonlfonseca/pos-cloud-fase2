{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ConsumeEvaluationEvents",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl",
        "sqs:ChangeMessageVisibility"
      ],
      "Resource": "arn:aws:sqs:us-east-1:257527265067:EvaluationEvent"
    },
    {
      "Sid": "WriteAnalytics",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:GetItem",
        "dynamodb:DescribeTable"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:257527265067:table/ToggleMasterAnalytics"
    }
  ]
}
